#!/bin/sh

BB=/bin/busybox

$BB mount -t devtmpfs devtmpfs /dev
$BB mount -t proc proc /proc
$BB mount -t sysfs sysfs /sys

$BB echo "=== Debian Initramfs (kernel 6.12 - RAID5) ==="

# Load al_eth network module
$BB echo "Loading al_eth module..."
$BB insmod /lib/modules/al_eth.ko
$BB insmod /lib/modules/al_thermal.ko
$BB insmod /lib/modules/al_nand.ko

# RAID modules are built-in, no insmod needed

# Wait for SATA disks to appear (PCI deferred probe)
$BB echo "Waiting for SATA disks..."
i=0
while [ ! -b /dev/sdb1 ] && [ $i -lt 30 ]; do
    $BB sleep 1
    i=$(($i + 1))
done

if [ ! -b /dev/sdb1 ]; then
    $BB echo "TIMEOUT waiting for SATA disks"
    $BB cat /proc/partitions
    exec $BB sh
fi

# Assemble RAID array
$BB echo "Assembling RAID array..."
/bin/mdadm --assemble --run /dev/md0 /dev/sda1 /dev/sdb1 /dev/sdc1 /dev/sdd1
$BB sleep 2

if [ ! -b /dev/md0 ]; then
    $BB echo "FAILED to assemble RAID"
    $BB cat /proc/mdstat
    exec $BB sh
fi

# Mount rootfs
$BB echo "Mounting /dev/md0..."
$BB mount -t ext4 /dev/md0 /mnt
if [ $? -ne 0 ]; then
    $BB echo "FAILED to mount /dev/md0"
    exec $BB sh
fi

# Copy modules to rootfs (use full kernel version for depmod)
KVER=$($BB uname -r)
$BB mkdir -p /mnt/lib/modules/$KVER
$BB cp /lib/modules/*.ko /mnt/lib/modules/$KVER/

$BB echo "Switching to Debian on RAID5..."
exec $BB switch_root /mnt /sbin/init
