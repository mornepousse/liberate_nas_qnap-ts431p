		board-cfg {
			id = "alpine_db_qnap";
			u-boot-offset = <0x20000>;

			pinctrl_init {
				pinctrl-0 = <0x07 0x08 0x09 0x0a>;
			};

			gpio_init {
				gpio-list = <0x00 0x00 0x00 0x20 0x00 0x00 0x21 0x00 0x00 0x22 0x00 0x00 0x23 0x00 0x00 0x24 0x00 0x00 0x25 0x00 0x00 0x01 0x01 0x00 0x02 0x01 0x00 0x03 0x01 0x00 0x04 0x01 0x00 0x05 0x01 0x00 0x26 0x01 0x01 0x27 0x01 0x01 0x28 0x01 0x00 0x29 0x01 0x00 0x2a 0x01 0x01 0x2b 0x01 0x00 0x1c 0x01 0x00 0x1e 0x01 0x00>;
			};

			serdes {

				group0 {
					interface = "pcie_g2x2_pcie_g2x2";
					ref-clock = "left";
					active-lanes = <0x00 0x01 0x02 0x03>;
					inv-tx-lanes;
					inv-rx-lanes;
					ssc = "disabled";
				};

				group1 {
					interface = "off_bp";
					ref-clock = "100Mhz";
					active-lanes = <0x00 0x01 0x02 0x03>;
					inv-tx-lanes;
					inv-rx-lanes;
					ssc = "disabled";
				};

				group2 {
					interface = "sata";
					ref-clock = "right";
					active-lanes = <0x00 0x01 0x02 0x03>;
					inv-tx-lanes;
					inv-rx-lanes;
					ssc = "disabled";
				};

				group3 {
					interface = "10gbe";
					ref-clock = "156.25Mhz";
					active-lanes = <0x03>;
					inv-tx-lanes;
					inv-rx-lanes;
					ssc = "disabled";
				};
			};

			ethernet {

				port0 {
					status = "disabled";
					mode = "auto-detect-auto-speed";
					i2c-id = <0x00>;

					10g-serial {
						dac = "disabled";
						dac-length = <0x03>;
						auto-neg = "disabled";
						link-training = "disabled";
						fec = "disabled";
					};

					retimer {
						exist = "disabled";
						i2c-bus = <0x00>;
						i2c-addr = <0x61>;
						channel = "A";
					};
				};

				port1 {
					status = "enabled";
					mode = "rgmii";

					ext_phy {
						phy_mgmt_if = "mdc-mdio";
						phy-addr = <0x04>;
						mdc-mdio-freq = "1.0Mhz";
						auto-neg-mode = "out-of-band";
					};
				};

				port2 {
					status = "disabled";
					mode = "10g-serial";
					i2c-id = <0x02>;

					10g-serial {
						dac = "disabled";
						dac-length = <0x03>;
						auto-neg = "disabled";
						link-training = "disabled";
						fec = "disabled";
					};

					retimer {
						exist = "disabled";
						i2c-bus = <0x00>;
						i2c-addr = <0x61>;
						channel = "B";
					};
				};

				port3 {
					status = "enabled";
					mode = "rgmii";

					ext_phy {
						phy_mgmt_if = "mdc-mdio";
						phy-addr = <0x05>;
						mdc-mdio-freq = "1.0Mhz";
						auto-neg-mode = "out-of-band";
					};
				};
			};

			pcie {
				ep-ports;

				port0 {
					status = "enabled";
					gen = <0x02>;
					width = <0x02>;
				};

				port1 {
					status = "enabled";
					gen = <0x02>;
					width = <0x02>;
				};

				port2 {
					status = "disabled";
					gen = <0x03>;
					width = <0x04>;
				};
			};
		};

		sata_sw_leds {
			compatible = "annapurna-labs,al-sata-sw-leds";

			led@0 {
				label = "host 0, port 0 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x08>;
				port = <0x03>;
				gpios = <0x0b 0x01 0x00>;
			};

			led@1 {
				label = "host 0, port 1 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x08>;
				port = <0x02>;
				gpios = <0x0b 0x02 0x00>;
			};

			led@2 {
				label = "host 0, port 2 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x08>;
				port = <0x01>;
				gpios = <0x0c 0x06 0x00>;
			};

			led@3 {
				label = "host 0, port 3 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x08>;
				port = <0x00>;
				gpios = <0x0c 0x07 0x00>;
			};

			led@4 {
				label = "host 1, port 4 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x09>;
				port = <0x00>;
				gpios = <0x0d 0x00 0x00>;
			};

			led@5 {
				label = "host 1, port 5 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x09>;
				port = <0x01>;
				gpios = <0x0d 0x01 0x00>;
			};

			led@6 {
				label = "host 1, port 6 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x09>;
				port = <0x02>;
				gpios = <0x0b 0x04 0x00>;
			};

			led@7 {
				label = "host 1, port 7 activity&presence led";
				pci_domain = <0x00>;
				pci_bus = <0x00>;
				pci_dev = <0x09>;
				port = <0x03>;
				gpios = <0x0b 0x05 0x00>;
			};
		};
	};

	hypervisor {
	};
